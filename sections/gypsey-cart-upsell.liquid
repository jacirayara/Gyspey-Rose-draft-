{% render 'gypsey-brand' %}

{% style %}
  .gypsey-cart-upsell .page-width {
    padding-block: clamp(2rem, 3vw, 3.2rem);
  }

  .gypsey-cart-upsell__inner {
    align-items: center;
    background: var(--gr-blush);
    border: 0.1rem solid var(--gr-line);
    border-radius: var(--gr-radius);
    display: flex;
    flex-wrap: wrap;
    gap: 1.6rem 2.4rem;
    justify-content: space-between;
    padding: clamp(1.8rem, 3vw, 2.8rem);
  }

  .gypsey-cart-upsell__inner > div {
    flex: 1 1 32rem;
  }

  .gypsey-cart-upsell h2 {
    font-size: clamp(2.2rem, 3vw, 3rem);
    line-height: 1.1;
    margin: 0.4rem 0 0;
  }

  .gypsey-cart-upsell p {
    color: var(--gr-body-soft);
    font-size: 1.6rem;
    line-height: 1.55;
    margin: 0.8rem 0 0;
  }
{% endstyle %}

<section class="gr-section gypsey-cart-upsell" aria-labelledby="gypsey-cart-upsell-title">
  <div class="page-width">
    <div class="gypsey-cart-upsell__inner">
      <div>
        {% if section.settings.eyebrow != blank %}
          <p class="gr-eyebrow">{{ section.settings.eyebrow }}</p>
        {% endif %}
        <h2 id="gypsey-cart-upsell-title">{{ section.settings.heading }}</h2>
        <p>{{ section.settings.text }}</p>
      </div>
      {% if section.settings.button_label != blank %}
        <a class="gr-btn" href="{{ section.settings.button_link }}">{{ section.settings.button_label }}</a>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Gypsey cart upsell",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Complete the look"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Add a hand-sourced Indian silver necklace."
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "A simple silver piece turns a cotton dress into a full Gypsey Rose outfit."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop Accessories"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Gypsey cart upsell"
    }
  ]
}
{% endschema %}
