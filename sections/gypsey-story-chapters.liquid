{% render 'gypsey-brand' %}

{% style %}
  .gypsey-story-chapters {
    background: linear-gradient(180deg, var(--gr-white) 0%, var(--gr-blush) 100%);
  }

  .gypsey-story-chapters__inner {
    display: grid;
    gap: clamp(2.8rem, 5vw, 6rem);
    grid-template-columns: minmax(22rem, 0.72fr) minmax(0, 1.28fr);
    padding-block: clamp(4rem, 8vw, 8rem);
  }

  .gypsey-story-chapters__intro {
    position: sticky;
    top: 2rem;
  }

  .gypsey-story-chapters h2 {
    font-size: clamp(3.2rem, 5vw, 6rem);
    line-height: 1.02;
    margin: 0;
  }

  .gypsey-story-chapters__lead {
    color: var(--gr-body-soft);
    font-size: 1.8rem;
    line-height: 1.6;
    margin-top: 2rem;
  }

  .gypsey-story-chapters__list {
    display: grid;
    gap: 1.2rem;
  }

  .gypsey-story-chapters__chapter {
    background: var(--gr-white);
    border: 0.1rem solid var(--gr-line);
    border-radius: var(--gr-radius);
    display: grid;
    gap: 1.6rem;
    grid-template-columns: 6rem minmax(0, 1fr);
    padding: clamp(2rem, 3.5vw, 3.2rem);
  }

  .gypsey-story-chapters__number {
    align-items: center;
    background: var(--gr-blush);
    border: 0.1rem solid var(--gr-lavender);
    border-radius: 999px;
    color: var(--gr-green);
    display: inline-flex;
    font-family: var(--gr-serif);
    font-size: 1.9rem;
    height: 5rem;
    justify-content: center;
    width: 5rem;
  }

  .gypsey-story-chapters__chapter h3 {
    font-size: clamp(2rem, 3vw, 2.8rem);
    margin: 0;
  }

  .gypsey-story-chapters__chapter p {
    color: var(--gr-body-soft);
    font-size: 1.6rem;
    line-height: 1.62;
    margin: 0.8rem 0 0;
  }

  @media screen and (max-width: 899px) {
    .gypsey-story-chapters__inner {
      grid-template-columns: 1fr;
    }

    .gypsey-story-chapters__intro {
      position: static;
    }
  }
{% endstyle %}

<section class="gr-section gypsey-story-chapters" aria-labelledby="gypsey-story-chapters-title">
  <div class="gypsey-story-chapters__inner page-width">
    <div class="gypsey-story-chapters__intro">
      {% if section.settings.eyebrow != blank %}
        <p class="gr-eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}
      <h2 id="gypsey-story-chapters-title">{{ section.settings.heading }}</h2>
      <p class="gypsey-story-chapters__lead">{{ section.settings.lead }}</p>
    </div>

    <div class="gypsey-story-chapters__list">
      {% for block in section.blocks %}
        <article class="gypsey-story-chapters__chapter" {{ block.shopify_attributes }}>
          <span class="gypsey-story-chapters__number">{{ forloop.index }}</span>
          <div>
            <h3>{{ block.settings.heading }}</h3>
            <p>{{ block.settings.text }}</p>
          </div>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Gypsey story chapters",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "The story behind the clothes"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "From a sourcing journey to a cotton lifestyle."
    },
    {
      "type": "textarea",
      "id": "lead",
      "label": "Lead",
      "default": "Feel the people, fabric, and craft behind every print — before you ever reach checkout."
    }
  ],
  "blocks": [
    {
      "type": "chapter",
      "name": "Chapter",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Chapter heading"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Chapter copy"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Gypsey story chapters"
    }
  ]
}
{% endschema %}
