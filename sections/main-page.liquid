<link rel="stylesheet" href="{{ 'section-main-page.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-rte.css' | asset_url }}" media="print" onload="this.media='all'">

<noscript>{{ 'section-main-page.css' | asset_url | stylesheet_tag }}</noscript>
<noscript>{{ 'component-rte.css' | asset_url | stylesheet_tag }}</noscript>

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  .section-{{ section.id }}-about-hero {
    margin-bottom: clamp(2.4rem, 5vw, 5.6rem);
    max-height: 78rem;
    overflow: hidden;
  }

  .section-{{ section.id }}-about-hero img {
    display: block;
    height: min(78rem, 72vw);
    min-height: 42rem;
    object-fit: cover;
    object-position: 50% 45%;
    width: 100%;
  }

  @media screen and (max-width: 749px) {
    .section-{{ section.id }}-about-hero img {
      height: 62rem;
      object-position: 52% 42%;
    }
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{%- if page.handle == 'about-us' -%}
  <div class="section-{{ section.id }}-about-hero">
    <img
      src="{{ 'gypsey-about-founders.png' | asset_url }}"
      alt="Gypsey Rose mother and daughter founders wearing red floral cotton dresses"
      width="1127"
      height="2000"
      loading="eager"
    >
  </div>
{%- endif -%}

<div class="page-width page-width--narrow section-{{ section.id }}-padding">
  <h1 class="main-page-title page-title h0">
    {{ page.title | escape }}
  </h1>
  <div class="rte">
    {{ page.content }}
  </div>
</div>

{% schema %}
{
  "name": "t:sections.main-page.name",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ]
}
{% endschema %}
