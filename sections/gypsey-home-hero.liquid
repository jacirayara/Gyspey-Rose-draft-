{% liquid
  assign hero_image = section.settings.hero_image
  assign portrait_image = section.settings.portrait_image
%}

{% render 'gypsey-brand' %}

{% style %}
  .gypsey-home-hero {
    background:
      radial-gradient(120% 90% at 88% 8%, var(--gr-blush) 0%, rgba(251, 240, 246, 0) 58%),
      var(--gr-white);
    overflow: hidden;
    position: relative;
  }

  .gypsey-home-hero__inner {
    align-items: center;
    display: grid;
    gap: clamp(2.8rem, 5vw, 6.4rem);
    grid-template-columns: minmax(0, 1fr) minmax(28rem, 1.02fr);
    min-height: min(78rem, calc(100vh - 8rem));
    padding-block: clamp(4.8rem, 8vw, 9.2rem);
    position: relative;
    z-index: 1;
  }

  .gypsey-home-hero h1 {
    font-size: clamp(4rem, 7.4vw, 8.4rem);
    line-height: 1.02;
    margin: 0;
    max-width: 10em;
  }

  .gypsey-home-hero__text {
    color: var(--gr-body-soft);
    font-size: clamp(1.6rem, 1.6vw, 1.9rem);
    line-height: 1.62;
    margin: 2.4rem 0 0;
    max-width: 40em;
  }

  .gypsey-home-hero__actions {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    gap: 1.6rem;
    margin-top: 3.2rem;
  }

  .gypsey-home-hero__proof {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: clamp(2.8rem, 4vw, 4rem);
    max-width: 54rem;
  }

  .gypsey-home-hero__proof span {
    background: var(--gr-blush);
    border: 0.1rem solid var(--gr-line);
    border-radius: 999px;
    color: var(--gr-green);
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    padding: 0.9rem 1.6rem;
  }

  .gypsey-home-hero__media {
    display: grid;
    gap: clamp(1.2rem, 2vw, 2rem);
    grid-template-columns: minmax(0, 1fr) minmax(11rem, 0.44fr);
    position: relative;
  }

  .gypsey-home-hero__image {
    background: var(--gr-blush-deep);
    border-radius: var(--gr-radius);
    margin: 0;
    overflow: hidden;
    position: relative;
  }

  .gypsey-home-hero__image--main {
    aspect-ratio: 4 / 5;
  }

  .gypsey-home-hero__image--portrait {
    align-self: end;
    aspect-ratio: 3 / 4;
    margin-bottom: clamp(1.2rem, 6vw, 6rem);
  }

  .gypsey-home-hero__image img {
    height: 100%;
    inset: 0;
    object-fit: cover;
    position: absolute;
    width: 100%;
  }

  .gypsey-home-hero__note {
    background: var(--gr-white);
    border: 0.1rem solid var(--gr-line);
    border-radius: var(--gr-radius);
    bottom: clamp(1rem, 3vw, 2.4rem);
    box-shadow: 0 1.2rem 3.2rem rgba(63, 107, 56, 0.1);
    color: var(--gr-green);
    font-family: var(--gr-serif);
    font-size: 1.5rem;
    font-style: italic;
    left: clamp(1rem, 3vw, 2.4rem);
    max-width: 21rem;
    padding: 1.4rem 1.8rem;
    position: absolute;
  }

  @media screen and (max-width: 899px) {
    .gypsey-home-hero__inner {
      grid-template-columns: 1fr;
      min-height: auto;
    }

    .gypsey-home-hero__media {
      grid-template-columns: 1fr;
    }

    .gypsey-home-hero__image--portrait {
      display: none;
    }
  }
{% endstyle %}

<section class="gr-section gypsey-home-hero" aria-labelledby="gypsey-home-hero-title">
  <div class="gypsey-home-hero__inner page-width">
    <div class="gypsey-home-hero__copy">
      {% if section.settings.eyebrow != blank %}
        <p class="gr-eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}
      <h1 id="gypsey-home-hero-title">{{ section.settings.heading }}</h1>
      <p class="gypsey-home-hero__text">{{ section.settings.text }}</p>

      <div class="gypsey-home-hero__actions">
        {% if section.settings.primary_label != blank %}
          <a class="gr-btn" href="{{ section.settings.primary_link }}">{{ section.settings.primary_label }}</a>
        {% endif %}
        {% if section.settings.secondary_label != blank %}
          <a class="gr-link" href="{{ section.settings.secondary_link }}">{{ section.settings.secondary_label }}</a>
        {% endif %}
      </div>

      <div class="gypsey-home-hero__proof" aria-label="Gypsey Rose values">
        <span>100% Pure Cotton</span>
        <span>Handmade in India</span>
        <span>Custom made for you</span>
      </div>
    </div>

    <div class="gypsey-home-hero__media">
      <figure class="gypsey-home-hero__image gypsey-home-hero__image--main">
        {% if hero_image != blank %}
          <img
            src="{{ hero_image | image_url: width: 1400 }}"
            srcset="{{ hero_image | image_url: width: 700 }} 700w, {{ hero_image | image_url: width: 1400 }} 1400w"
            sizes="(min-width: 900px) 46vw, 100vw"
            alt="{{ section.settings.hero_alt | escape }}"
            width="1120"
            height="1400"
            loading="eager"
          >
        {% else %}
          <img
            src="{{ 'gypsey-about-founders.png' | asset_url }}"
            alt="{{ section.settings.hero_alt | escape }}"
            width="1127"
            height="2000"
            loading="eager"
          >
        {% endif %}
      </figure>

      <figure class="gypsey-home-hero__image gypsey-home-hero__image--portrait">
        {% if portrait_image != blank %}
          <img
            src="{{ portrait_image | image_url: width: 700 }}"
            alt="{{ section.settings.portrait_alt | escape }}"
            width="600"
            height="800"
            loading="eager"
          >
        {% else %}
          <img
            src="{{ 'gypsey-about-founders.png' | asset_url }}"
            alt="{{ section.settings.portrait_alt | escape }}"
            width="600"
            height="800"
            loading="eager"
          >
        {% endif %}
      </figure>

      {% if section.settings.note != blank %}
        <div class="gypsey-home-hero__note">{{ section.settings.note }}</div>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Gypsey editorial hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Main image"
    },
    {
      "type": "image_picker",
      "id": "portrait_image",
      "label": "Portrait image"
    },
    {
      "type": "text",
      "id": "hero_alt",
      "label": "Main image alt text",
      "default": "Gypsey Rose 100% cotton clothing, handmade in India"
    },
    {
      "type": "text",
      "id": "portrait_alt",
      "label": "Portrait image alt text",
      "default": "Gypsey Rose mother and daughter"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "100% Pure Cotton, handmade in India"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Cotton made joyful."
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Gypsey Rose welcomes women into 100% pure cotton clothing that feels handmade, detailed, and naturally pleasurable to wear — or custom made just for you."
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button label",
      "default": "Shop Cotton Dresses"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary link label",
      "default": "Read Our Story"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary link"
    },
    {
      "type": "text",
      "id": "note",
      "label": "Floating note",
      "default": "Chosen by hand, not by catalogue."
    }
  ],
  "presets": [
    {
      "name": "Gypsey editorial hero"
    }
  ]
}
{% endschema %}
