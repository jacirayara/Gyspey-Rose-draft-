{% liquid
  assign hero_image = images['WhatsApp_Image_2026-03-03_at_14.47.17.jpg']
  assign founder_image = images['TESS_BRITZ_GYPSEY_ROSE.jpg']
  assign india_image = images['WhatsApp_Image_2026-03-03_at_14.47.16.jpg']
%}

{% style %}
  .gypsey-story {
    --gypsey-pink: #eb3fa0;
    --gypsey-coral: #f25f4c;
    --gypsey-teal: #087f7b;
    --gypsey-ink: #211a1d;
    --gypsey-sun: #f7b733;
    background:
      linear-gradient(135deg, rgba(235, 63, 160, 0.12), rgba(8, 127, 123, 0.08)),
      #fff;
    overflow: hidden;
  }

  .gypsey-story__inner {
    align-items: center;
    display: grid;
    gap: clamp(2.4rem, 5vw, 7rem);
    grid-template-columns: minmax(0, 0.9fr) minmax(280px, 1.1fr);
    padding-block: clamp(3.6rem, 7vw, 7.2rem);
  }

  .gypsey-story__copy h2 {
    color: var(--gypsey-ink);
    font-size: clamp(3.2rem, 6vw, 6.4rem);
    letter-spacing: 0;
    line-height: 0.98;
    margin: 0;
    max-width: 9.5em;
  }

  .gypsey-story__eyebrow {
    color: var(--gypsey-teal);
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    margin: 0 0 1.2rem;
    text-transform: uppercase;
  }

  .gypsey-story__lead {
    color: rgba(33, 26, 29, 0.78);
    font-size: clamp(1.6rem, 2vw, 2rem);
    line-height: 1.6;
    margin: 2rem 0 2.4rem;
    max-width: 38em;
  }

  .gypsey-story__proof {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin: 0 0 2.6rem;
  }

  .gypsey-story__proof span {
    border: 0.1rem solid rgba(8, 127, 123, 0.24);
    border-radius: 999px;
    color: var(--gypsey-ink);
    font-size: 1.3rem;
    font-weight: 700;
    padding: 0.8rem 1.2rem;
  }

  .gypsey-story__media {
    display: grid;
    gap: clamp(1rem, 2vw, 1.8rem);
    grid-template-columns: 1.35fr 0.85fr;
    min-height: 42rem;
  }

  .gypsey-story__image {
    background: var(--gypsey-sun);
    margin: 0;
    min-height: 0;
    overflow: hidden;
  }

  .gypsey-story__image--large {
    grid-row: span 2;
  }

  .gypsey-story__image img {
    display: block;
    height: 100%;
    min-height: 20rem;
    object-fit: cover;
    width: 100%;
  }

  @media screen and (max-width: 749px) {
    .gypsey-story__inner,
    .gypsey-story__media {
      grid-template-columns: 1fr;
    }

    .gypsey-story__media {
      min-height: auto;
    }

    .gypsey-story__image--large {
      grid-row: auto;
    }
  }
{% endstyle %}

<section class="gypsey-story" aria-labelledby="gypsey-story-title">
  <div class="gypsey-story__inner page-width">
    <div class="gypsey-story__copy">
      <p class="gypsey-story__eyebrow">{{ section.settings.eyebrow }}</p>
      <h2 id="gypsey-story-title">{{ section.settings.heading }}</h2>
      <p class="gypsey-story__lead">{{ section.settings.lead }}</p>
      <div class="gypsey-story__proof" aria-label="Gypsey Rose values">
        <span>100% cotton</span>
        <span>Mother-daughter led</span>
        <span>Ethically sourced in India</span>
      </div>
      <a class="button button--primary" href="{{ section.settings.button_link }}">{{ section.settings.button_label }}</a>
    </div>

    <div class="gypsey-story__media" aria-label="Gypsey Rose lifestyle imagery">
      <figure class="gypsey-story__image gypsey-story__image--large">
        {% if hero_image != blank %}
          <img
            src="{{ hero_image | image_url: width: 1000 }}"
            alt="Vibrant Gypsey Rose cotton clothing"
            loading="lazy"
            width="1000"
            height="1250"
          >
        {% else %}
          <img
            src="{{ 'sample_0_dresses.jpg' | asset_url }}"
            alt="Vibrant cotton dresses"
            loading="lazy"
            width="1000"
            height="1250"
          >
        {% endif %}
      </figure>
      <figure class="gypsey-story__image gypsey-story__image--small">
        {% if founder_image != blank %}
          <img
            src="{{ founder_image | image_url: width: 700 }}"
            alt="Gypsey Rose founder lifestyle moment"
            loading="lazy"
            width="700"
            height="700"
          >
        {% else %}
          <img
            src="{{ 'sample_1_rori_rose.jpg' | asset_url }}"
            alt="Rori Rose cotton dress"
            loading="lazy"
            width="700"
            height="700"
          >
        {% endif %}
      </figure>
      <figure class="gypsey-story__image gypsey-story__image--small">
        {% if india_image != blank %}
          <img
            src="{{ india_image | image_url: width: 700 }}"
            alt="Cotton clothing inspired by sourcing trips in India"
            loading="lazy"
            width="700"
            height="700"
          >
        {% else %}
          <img
            src="{{ 'sample_4_kaftans.jpg' | asset_url }}"
            alt="Printed cotton kaftans"
            loading="lazy"
            width="700"
            height="700"
          >
        {% endif %}
      </figure>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Gypsey story",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "From India, with heart"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "A mother-daughter story told in vibrant cotton."
    },
    {
      "type": "textarea",
      "id": "lead",
      "label": "Lead text",
      "default": "Gypsey Rose is built around face-to-face sourcing, breathable 100% cotton, and joyful pieces chosen for real women living bright, textured lives."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Read Our Story"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Gypsey story"
    }
  ]
}
{% endschema %}
