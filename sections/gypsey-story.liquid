{% liquid
  assign hero_image = images['WhatsApp_Image_2026-03-03_at_14.47.17.jpg']
  assign founder_image = images['TESS_BRITZ_GYPSEY_ROSE.jpg']
  assign india_image = images['WhatsApp_Image_2026-03-03_at_14.47.16.jpg']
%}

{% render 'gypsey-brand' %}

{% style %}
  .gypsey-story {
    background:
      linear-gradient(180deg, var(--gr-white) 0%, var(--gr-blush) 100%);
    overflow: hidden;
  }

  .gypsey-story__inner {
    align-items: center;
    display: grid;
    gap: clamp(2.8rem, 5vw, 6.4rem);
    grid-template-columns: minmax(0, 0.92fr) minmax(28rem, 1.08fr);
    padding-block: clamp(4rem, 7vw, 7.6rem);
  }

  .gypsey-story__copy h2 {
    font-size: clamp(3.2rem, 5.4vw, 5.8rem);
    line-height: 1.04;
    margin: 0;
    max-width: 10em;
  }

  .gypsey-story__lead {
    color: var(--gr-body-soft);
    font-size: clamp(1.6rem, 1.8vw, 1.9rem);
    line-height: 1.62;
    margin: 2rem 0 2.4rem;
    max-width: 38em;
  }

  .gypsey-story__proof {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin: 0 0 2.8rem;
  }

  .gypsey-story__proof span {
    background: var(--gr-white);
    border: 0.1rem solid var(--gr-line);
    border-radius: 999px;
    color: var(--gr-green);
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    padding: 0.9rem 1.6rem;
  }

  .gypsey-story__media {
    display: grid;
    gap: clamp(1rem, 1.6vw, 1.6rem);
    grid-template-columns: 1.3fr 0.9fr;
    grid-template-rows: repeat(2, 1fr);
  }

  .gypsey-story__image {
    background: var(--gr-blush-deep);
    border-radius: var(--gr-radius);
    margin: 0;
    overflow: hidden;
    position: relative;
  }

  .gypsey-story__image--large {
    grid-row: span 2;
  }

  .gypsey-story__image img {
    height: 100%;
    inset: 0;
    object-fit: cover;
    position: absolute;
    width: 100%;
  }

  @media screen and (max-width: 749px) {
    .gypsey-story__inner {
      grid-template-columns: 1fr;
    }

    .gypsey-story__media {
      grid-template-rows: none;
    }

    .gypsey-story__image {
      aspect-ratio: 4 / 5;
    }

    .gypsey-story__image--large {
      grid-column: span 2;
      grid-row: auto;
      aspect-ratio: 16 / 10;
    }
  }
{% endstyle %}

<section class="gr-section gypsey-story" aria-labelledby="gypsey-story-title">
  <div class="gypsey-story__inner page-width">
    <div class="gypsey-story__copy">
      {% if section.settings.eyebrow != blank %}
        <p class="gr-eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}
      <h2 id="gypsey-story-title">{{ section.settings.heading }}</h2>
      <p class="gypsey-story__lead">{{ section.settings.lead }}</p>
      <div class="gypsey-story__proof" aria-label="Gypsey Rose values">
        <span>100% Pure Cotton</span>
        <span>Handmade in India</span>
        <span>Custom made</span>
      </div>
      {% if section.settings.button_label != blank %}
        <a class="gr-btn" href="{{ section.settings.button_link }}">{{ section.settings.button_label }}</a>
      {% endif %}
    </div>

    <div class="gypsey-story__media" aria-label="Gypsey Rose lifestyle imagery">
      <figure class="gypsey-story__image gypsey-story__image--large">
        {% if hero_image != blank %}
          <img
            src="{{ hero_image | image_url: width: 1000 }}"
            alt="Gypsey Rose cotton clothing, handmade in India"
            loading="lazy"
            width="1000"
            height="1250"
          >
        {% else %}
          <img
            src="{{ 'sample_0_dresses.jpg' | asset_url }}"
            alt="Cotton dresses"
            loading="lazy"
            width="1000"
            height="1250"
          >
        {% endif %}
      </figure>
      <figure class="gypsey-story__image gypsey-story__image--small">
        {% if founder_image != blank %}
          <img
            src="{{ founder_image | image_url: width: 700 }}"
            alt="Gypsey Rose founder"
            loading="lazy"
            width="700"
            height="700"
          >
        {% else %}
          <img
            src="{{ 'sample_1_rori_rose.jpg' | asset_url }}"
            alt="Rori Rose cotton dress"
            loading="lazy"
            width="700"
            height="700"
          >
        {% endif %}
      </figure>
      <figure class="gypsey-story__image gypsey-story__image--small">
        {% if india_image != blank %}
          <img
            src="{{ india_image | image_url: width: 700 }}"
            alt="Cotton clothing inspired by sourcing trips in India"
            loading="lazy"
            width="700"
            height="700"
          >
        {% else %}
          <img
            src="{{ 'sample_4_kaftans.jpg' | asset_url }}"
            alt="Printed cotton kaftans"
            loading="lazy"
            width="700"
            height="700"
          >
        {% endif %}
      </figure>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Gypsey story",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Handmade in India, with heart"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "A mother-daughter story, told in pure cotton."
    },
    {
      "type": "textarea",
      "id": "lead",
      "label": "Lead text",
      "default": "Gypsey Rose is built around face-to-face sourcing, breathable 100% pure cotton, and joyful pieces chosen for real women living bright, textured lives."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Read Our Story"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Gypsey story"
    }
  ]
}
{% endschema %}
