{% liquid
  assign hero_image = images['WhatsApp_Image_2026-03-03_at_14.47.17.jpg']
  assign founder_image = images['TESS_BRITZ_GYPSEY_ROSE.jpg']
  assign india_image = images['WhatsApp_Image_2026-03-03_at_14.47.16.jpg']
%}

<section class="gypsey-story" aria-labelledby="gypsey-story-title">
  <div class="gypsey-story__inner page-width">
    <div class="gypsey-story__copy">
      <p class="gypsey-story__eyebrow">{{ section.settings.eyebrow }}</p>
      <h2 id="gypsey-story-title">{{ section.settings.heading }}</h2>
      <p class="gypsey-story__lead">{{ section.settings.lead }}</p>
      <div class="gypsey-story__proof" aria-label="Gypsey Rose values">
        <span>100% cotton</span>
        <span>Mother-daughter led</span>
        <span>Ethically sourced in India</span>
      </div>
      <a class="button button--primary" href="{{ section.settings.button_link }}">{{ section.settings.button_label }}</a>
    </div>

    <div class="gypsey-story__media" aria-label="Gypsey Rose lifestyle imagery">
      <figure class="gypsey-story__image gypsey-story__image--large">
        {% if hero_image != blank %}
          <img
            src="{{ hero_image | image_url: width: 1000 }}"
            alt="Vibrant Gypsey Rose cotton clothing"
            loading="lazy"
            width="1000"
            height="1250"
          >
        {% else %}
          <img
            src="{{ 'sample_0_dresses.jpg' | asset_url }}"
            alt="Vibrant cotton dresses"
            loading="lazy"
            width="1000"
            height="1250"
          >
        {% endif %}
      </figure>
      <figure class="gypsey-story__image gypsey-story__image--small">
        {% if founder_image != blank %}
          <img
            src="{{ founder_image | image_url: width: 700 }}"
            alt="Gypsey Rose founder lifestyle moment"
            loading="lazy"
            width="700"
            height="700"
          >
        {% else %}
          <img
            src="{{ 'sample_1_rori_rose.jpg' | asset_url }}"
            alt="Rori Rose cotton dress"
            loading="lazy"
            width="700"
            height="700"
          >
        {% endif %}
      </figure>
      <figure class="gypsey-story__image gypsey-story__image--small">
        {% if india_image != blank %}
          <img
            src="{{ india_image | image_url: width: 700 }}"
            alt="Cotton clothing inspired by sourcing trips in India"
            loading="lazy"
            width="700"
            height="700"
          >
        {% else %}
          <img
            src="{{ 'sample_4_kaftans.jpg' | asset_url }}"
            alt="Printed cotton kaftans"
            loading="lazy"
            width="700"
            height="700"
          >
        {% endif %}
      </figure>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Gypsey story",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "From India, with heart"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "A mother-daughter story told in vibrant cotton."
    },
    {
      "type": "textarea",
      "id": "lead",
      "label": "Lead text",
      "default": "Gypsey Rose is built around face-to-face sourcing, breathable 100% cotton, and joyful pieces chosen for real women living bright, textured lives."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Read Our Story"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Gypsey story"
    }
  ]
}
{% endschema %}
