{% liquid
  assign feature_image = section.settings.feature_image
%}

{% render 'gypsey-brand' %}

{% style %}
  .gypsey-story {
    background:
      linear-gradient(180deg, var(--gr-white) 0%, var(--gr-blush) 100%);
    overflow: hidden;
  }

  .gypsey-story__inner {
    align-items: center;
    display: grid;
    gap: clamp(2.8rem, 5vw, 6.4rem);
    grid-template-columns: minmax(0, 1fr) minmax(30rem, 0.92fr);
    padding-block: clamp(4rem, 7vw, 7.6rem);
  }

  .gypsey-story__copy h2 {
    font-size: clamp(3.2rem, 5.4vw, 5.8rem);
    line-height: 1.04;
    margin: 0;
    max-width: 10em;
  }

  .gypsey-story__lead {
    color: var(--gr-body-soft);
    font-size: clamp(1.6rem, 1.8vw, 1.9rem);
    line-height: 1.62;
    margin: 2rem 0 2.4rem;
    max-width: 38em;
  }

  .gypsey-story__proof {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin: 0 0 2.8rem;
  }

  .gypsey-story__proof span {
    background: var(--gr-white);
    border: 0.1rem solid var(--gr-line);
    border-radius: 999px;
    color: var(--gr-green);
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    padding: 0.9rem 1.6rem;
  }

  .gypsey-story__media {
    aspect-ratio: 16 / 10;
    background: var(--gr-blush-deep);
    border-radius: var(--gr-radius);
    margin: 0;
    overflow: hidden;
    position: relative;
  }

  .gypsey-story__media img {
    height: 100%;
    inset: 0;
    object-fit: cover;
    object-position: center;
    position: absolute;
    width: 100%;
  }

  @media screen and (max-width: 749px) {
    .gypsey-story__inner {
      grid-template-columns: 1fr;
    }

    .gypsey-story__media {
      aspect-ratio: 4 / 3;
    }
  }
{% endstyle %}

<section class="gr-section gypsey-story" aria-labelledby="gypsey-story-title">
  <div class="gypsey-story__inner page-width">
    <div class="gypsey-story__copy">
      {% if section.settings.eyebrow != blank %}
        <p class="gr-eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}
      <h2 id="gypsey-story-title">{{ section.settings.heading }}</h2>
      <p class="gypsey-story__lead">{{ section.settings.lead }}</p>
      <div class="gypsey-story__proof" aria-label="Gypsey Rose values">
        <span>100% Pure Cotton</span>
        <span>Handmade in India</span>
        <span>Custom made</span>
      </div>
      {% if section.settings.button_label != blank %}
        <a class="gr-btn" href="{{ section.settings.button_link }}">{{ section.settings.button_label }}</a>
      {% endif %}
    </div>

    <figure class="gypsey-story__media">
      {% if feature_image != blank %}
        <img
          src="{{ feature_image | image_url: width: 1200 }}"
          srcset="{{ feature_image | image_url: width: 600 }} 600w, {{ feature_image | image_url: width: 1200 }} 1200w"
          sizes="(min-width: 750px) 44vw, 100vw"
          alt="{{ section.settings.image_alt | escape }}"
          width="1120"
          height="1400"
          loading="lazy"
        >
      {% else %}
        <img
          src="{{ 'gypsey-about-founders.png' | asset_url }}"
          alt="{{ section.settings.image_alt | escape }}"
          width="1127"
          height="2000"
          loading="lazy"
        >
      {% endif %}
    </figure>
  </div>
</section>

{% schema %}
{
  "name": "Gypsey story",
  "settings": [
    {
      "type": "image_picker",
      "id": "feature_image",
      "label": "Feature image",
      "info": "Use the mother-and-daughter photo (the yellow-clothing image). Leave empty to use the founders image included with the theme."
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Image alt text",
      "default": "Gypsey Rose mother and daughter wearing cotton clothing"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Handmade in India, with heart"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "A mother-daughter story, told in pure cotton."
    },
    {
      "type": "textarea",
      "id": "lead",
      "label": "Lead text",
      "default": "Gypsey Rose is built around face-to-face sourcing, breathable 100% pure cotton, and joyful pieces chosen for real women living bright, textured lives."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Read Our Story"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Gypsey story"
    }
  ]
}
{% endschema %}
