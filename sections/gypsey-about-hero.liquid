{% style %}
  .gypsey-about-hero {
    --gypsey-about-ink: #211a1d;
    --gypsey-about-pink: #eb3fa0;
    --gypsey-about-teal: #087f7b;
    background: #fff;
  }

  .gypsey-about-hero__media {
    background: #f7f0f3;
    max-height: 78rem;
    overflow: hidden;
  }

  .gypsey-about-hero__media img {
    display: block;
    height: min(78rem, 72vw);
    min-height: 42rem;
    object-fit: cover;
    object-position: 50% 45%;
    width: 100%;
  }

  .gypsey-about-hero__copy {
    padding-block: clamp(2.4rem, 5vw, 5.6rem);
  }

  .gypsey-about-hero__eyebrow {
    color: var(--gypsey-about-teal);
    font-size: 1.2rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    margin: 0 0 1.2rem;
    text-transform: uppercase;
  }

  .gypsey-about-hero h1 {
    color: var(--gypsey-about-ink);
    font-size: clamp(3.2rem, 6vw, 7.2rem);
    letter-spacing: 0;
    line-height: 0.98;
    margin: 0;
    max-width: 10em;
  }

  .gypsey-about-hero__copy p:last-child {
    color: rgba(33, 26, 29, 0.76);
    font-size: clamp(1.6rem, 2vw, 2.1rem);
    line-height: 1.55;
    max-width: 46em;
  }

  @media screen and (max-width: 749px) {
    .gypsey-about-hero__media img {
      height: 62rem;
      object-position: 52% 42%;
    }
  }
{% endstyle %}

<section class="gypsey-about-hero" aria-labelledby="gypsey-about-hero-title">
  <div class="gypsey-about-hero__media">
    <img
      src="{{ 'gypsey-about-founders.png' | asset_url }}"
      alt="Gypsey Rose mother and daughter founders wearing red floral cotton dresses"
      width="1127"
      height="2000"
      loading="eager"
    >
  </div>
  <div class="gypsey-about-hero__copy page-width">
    <p class="gypsey-about-hero__eyebrow">{{ section.settings.eyebrow }}</p>
    <h1 id="gypsey-about-hero-title">{{ section.settings.heading }}</h1>
    <p>{{ section.settings.text }}</p>
  </div>
</section>

{% schema %}
{
  "name": "Gypsey about hero",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Our Story"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The mother-daughter heart of Gypsey Rose."
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "A brand built on colour, cotton, and the joy of finding beautiful pieces face-to-face."
    }
  ],
  "presets": [
    {
      "name": "Gypsey about hero"
    }
  ]
}
{% endschema %}
