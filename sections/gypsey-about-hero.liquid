{% render 'gypsey-brand' %}

{% style %}
  .gypsey-about-hero {
    background: var(--gr-white);
  }

  .gypsey-about-hero__inner {
    align-items: center;
    display: grid;
    gap: clamp(2.4rem, 4vw, 5.6rem);
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    padding-block: clamp(3.6rem, 6vw, 7.2rem);
  }

  .gypsey-about-hero__media {
    background: var(--gr-blush-deep);
    border-radius: var(--gr-radius);
    margin: 0;
    overflow: hidden;
    position: relative;
    aspect-ratio: 4 / 5;
  }

  .gypsey-about-hero__media img {
    height: 100%;
    inset: 0;
    object-fit: cover;
    object-position: 50% 40%;
    position: absolute;
    width: 100%;
  }

  .gypsey-about-hero h1 {
    font-size: clamp(3.2rem, 5.4vw, 6.4rem);
    line-height: 1.04;
    margin: 0;
    max-width: 11em;
  }

  .gypsey-about-hero__text {
    color: var(--gr-body-soft);
    font-size: clamp(1.6rem, 1.8vw, 2rem);
    line-height: 1.6;
    margin-top: 1.8rem;
    max-width: 40em;
  }

  @media screen and (max-width: 749px) {
    .gypsey-about-hero__inner {
      grid-template-columns: 1fr;
    }
  }
{% endstyle %}

<section class="gr-section gypsey-about-hero" aria-labelledby="gypsey-about-hero-title">
  <div class="gypsey-about-hero__inner page-width">
    <figure class="gypsey-about-hero__media">
      <img
        src="{{ 'gypsey-about-founders.png' | asset_url }}"
        alt="Gypsey Rose mother and daughter founders wearing red floral cotton dresses"
        width="1127"
        height="2000"
        loading="eager"
      >
    </figure>
    <div class="gypsey-about-hero__copy">
      {% if section.settings.eyebrow != blank %}
        <p class="gr-eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}
      <h1 id="gypsey-about-hero-title">{{ section.settings.heading }}</h1>
      <p class="gypsey-about-hero__text">{{ section.settings.text }}</p>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Gypsey about hero",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Our Story"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The mother-daughter heart of Gypsey Rose."
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "A brand built on colour, 100% pure cotton, and the joy of finding beautiful pieces face-to-face in India."
    }
  ],
  "presets": [
    {
      "name": "Gypsey about hero"
    }
  ]
}
{% endschema %}
