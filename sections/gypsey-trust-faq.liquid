{% render 'gypsey-brand' %}

{% style %}
  .gypsey-trust-faq {
    background: var(--gr-blush);
    border-block: 0.1rem solid var(--gr-line);
  }

  .gypsey-trust-faq .page-width {
    padding-block: clamp(3.6rem, 6vw, 6.4rem);
  }

  .gypsey-trust-faq__intro {
    max-width: 72rem;
  }

  .gypsey-trust-faq__intro h2 {
    font-size: clamp(2.8rem, 4vw, 4.6rem);
    line-height: 1.06;
    margin: 0;
  }

  .gypsey-trust-faq__intro p {
    color: var(--gr-body-soft);
    font-size: 1.7rem;
    line-height: 1.6;
    margin-top: 1.4rem;
  }

  .gypsey-trust-faq__signals {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    margin: 2.8rem 0;
  }

  .gypsey-trust-faq__signals span {
    align-items: center;
    background: var(--gr-white);
    border: 0.1rem solid var(--gr-line);
    border-radius: var(--gr-radius);
    color: var(--gr-green);
    display: flex;
    font-weight: 700;
    font-size: 1.4rem;
    min-height: 7rem;
    padding: 1.4rem 1.8rem;
  }

  .gypsey-trust-faq__questions {
    display: grid;
    gap: 0.8rem;
    max-width: 82rem;
  }

  .gypsey-trust-faq__questions details {
    background: var(--gr-white);
    border: 0.1rem solid var(--gr-line);
    border-radius: var(--gr-radius);
    overflow: hidden;
  }

  .gypsey-trust-faq__questions summary {
    align-items: center;
    color: var(--gr-green);
    cursor: pointer;
    display: flex;
    font-family: var(--gr-serif);
    font-size: 1.9rem;
    font-weight: 500;
    justify-content: space-between;
    list-style: none;
    padding: 1.8rem 2rem;
  }

  .gypsey-trust-faq__questions summary::-webkit-details-marker {
    display: none;
  }

  .gypsey-trust-faq__questions summary::after {
    color: var(--gr-lavender);
    content: "+";
    font-size: 2.4rem;
    font-weight: 400;
    line-height: 1;
    transition: transform 0.2s ease;
  }

  .gypsey-trust-faq__questions details[open] summary::after {
    transform: rotate(45deg);
  }

  .gypsey-trust-faq__questions p {
    color: var(--gr-body-soft);
    font-size: 1.6rem;
    line-height: 1.62;
    margin: 0;
    padding: 0 2rem 2rem;
  }

  @media screen and (max-width: 749px) {
    .gypsey-trust-faq__signals {
      grid-template-columns: 1fr 1fr;
    }
  }
{% endstyle %}

<section class="gr-section gypsey-trust-faq" aria-labelledby="gypsey-faq-title">
  <div class="page-width">
    <div class="gypsey-trust-faq__intro">
      {% if section.settings.eyebrow != blank %}
        <p class="gr-eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}
      <h2 id="gypsey-faq-title">{{ section.settings.heading }}</h2>
      <p>{{ section.settings.text }}</p>
    </div>

    <div class="gypsey-trust-faq__signals" aria-label="Store trust signals">
      <span>Handmade in India</span>
      <span>7-day returns</span>
      <span>Cool-wash cotton care</span>
      <span>Custom made on request</span>
    </div>

    <div class="gypsey-trust-faq__questions">
      <details open>
        <summary>How long does shipping take?</summary>
        <p>Each piece is prepared with care and dispatched from South Africa. Final delivery times are confirmed at checkout and may vary by address and courier availability.</p>
      </details>
      <details>
        <summary>What is the return policy?</summary>
        <p>Items can be returned within 7 days if the labels are attached and the garment is in the same condition as received.</p>
      </details>
      <details>
        <summary>How do I wash 100% pure cotton?</summary>
        <p>Use a cool machine wash, avoid wringing, and dry in the shade. Hand wash jackets in cold water to protect the fabric and embroidery.</p>
      </details>
      <details>
        <summary>How do I choose my size?</summary>
        <p>Use the size guide on each product page and choose the fit you prefer. Our cotton pieces are cut to feel easy, breathable, and forgiving on the body — and any piece can be custom made for you.</p>
      </details>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Gypsey trust and FAQ",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Before you buy"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Everything you need to feel confident."
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Intro text",
      "default": "Clear shipping, returns, cotton care, and sizing details, so every visitor can move from discovery to checkout with ease."
    }
  ],
  "presets": [
    {
      "name": "Gypsey trust and FAQ"
    }
  ]
}
{% endschema %}
