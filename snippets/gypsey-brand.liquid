{% comment %}
  Gypsey Rose brand system (2026 refresh)
  Shared design tokens + typography for all custom Gypsey sections.
  Palette, type and rules from the updated brand guidelines:
  white / blush / leaf green, pink used sparingly, lavender as second accent,
  Playfair Display headlines, Lato body, 8px radius, 1px hairline borders.
  Render once at the top of each Gypsey section: {% render 'gypsey-brand' %}
{% endcomment %}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Lato:wght@300;400;700&display=swap">

{% style %}
  :root {
    --gr-white: #ffffff;
    --gr-blush: #fbf0f6;
    --gr-blush-deep: #f3e2ec;
    --gr-green: #3f6b38;
    --gr-green-deep: #2f5029;
    --gr-body: #2d3a2b;
    --gr-body-soft: rgba(45, 58, 43, 0.74);
    --gr-pink: #eb3fa0;
    --gr-pink-deep: #c9247f;
    --gr-lavender: #c9a1d5;
    --gr-lavender-soft: #ecdcf0;
    --gr-line: rgba(63, 107, 56, 0.16);
    --gr-radius: 8px;
    --gr-serif: "Playfair Display", "Prata", Georgia, "Times New Roman", serif;
    --gr-sans: "Lato", -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
  }

  .gr-section {
    font-family: var(--gr-sans);
  }

  .gr-eyebrow {
    color: var(--gr-green);
    font-family: var(--gr-sans);
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    margin: 0 0 1.4rem;
    text-transform: uppercase;
  }

  .gr-section h1,
  .gr-section h2,
  .gr-section h3 {
    color: var(--gr-green);
    font-family: var(--gr-serif);
    font-weight: 500;
    letter-spacing: -0.01em;
  }

  .gr-section p {
    font-family: var(--gr-sans);
  }

  .gr-btn {
    align-items: center;
    background: var(--gr-pink);
    border: none;
    border-radius: var(--gr-radius);
    color: var(--gr-white);
    display: inline-flex;
    font-family: var(--gr-sans);
    font-size: 1.4rem;
    font-weight: 700;
    justify-content: center;
    letter-spacing: 0.04em;
    min-height: 5rem;
    padding: 0 2.8rem;
    text-decoration: none;
    transition: background 0.2s ease, transform 0.2s ease;
  }

  .gr-btn:hover {
    background: var(--gr-pink-deep);
    color: var(--gr-white);
    transform: translateY(-0.1rem);
  }

  .gr-link {
    align-items: center;
    color: var(--gr-green);
    display: inline-flex;
    font-family: var(--gr-sans);
    font-size: 1.4rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    min-height: 5rem;
    text-decoration: underline;
    text-decoration-color: var(--gr-lavender);
    text-decoration-thickness: 0.15rem;
    text-underline-offset: 0.45rem;
    transition: text-decoration-color 0.2s ease;
  }

  .gr-link:hover {
    color: var(--gr-green-deep);
    text-decoration-color: var(--gr-pink);
  }
{% endstyle %}
